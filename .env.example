# System timezone
TZ=America/New_York

# MQTT configuration
MQTT_HOST=localhost
MQTT_PORT=1883

# ESPHome web interface
ESPHOME_PORT=6052

# WiFi network used by ESP devices
WIFI_SSID=your_wifi_name
WIFI_PASSWORD=your_wifi_password

# Optional Home Assistant API
HA_URL=http://localhost:8123
HA_TOKEN=your_home_assistant_token
